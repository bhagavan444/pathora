# Backend Environment Variables
# -----------------------------
# Copy this file to .env and replace the placeholder values with actual secrets.
# NEVER commit the actual .env file to version control.

# Security
SECRET_KEY=replace_me_with_a_strong_random_string_in_production

# Databases
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@db:5432/ai_db
MONGODB_URI=mongodb://mongodb:27017
REDIS_URI=redis://redis:6379/0
QDRANT_URL=http://localhost:6333

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Worker
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
